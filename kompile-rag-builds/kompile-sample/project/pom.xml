    <!-- Profile for running with Valgrind memory checker -->
    <profile>
      <id>valgrind</id>
      <properties>
        <test.runner.prefix>valgrind --leak-check=full --show-leak-kinds=all</test.runner.prefix>
      </properties>
    </profile>

    <!-- Profile for minimal valgrind (faster, less detail) -->
    <profile>
      <id>valgrind-minimal</id>
      <properties>
        <test.runner.prefix>valgrind --leak-check=summary --show-leak-kinds=definite</test.runner.prefix>
      </properties>
    </profile>

    <!-- Profile for running with AddressSanitizer -->
    <profile>
      <id>asan</id>
      <properties>
        <test.runner.prefix>asan</test.runner.prefix>
        <test.asan.options>alloc_dealloc_mismatch=0:detect_leaks=1:new_delete_type_mismatch=0:halt_on_error=0:exitcode=0</test.asan.options>
      </properties>
    </profile>

    <!-- Profile for running with CUDA compute-sanitizer -->
    <profile>
      <id>compute-sanitizer</id>
      <properties>
        <test.runner.prefix>compute-sanitizer --tool memcheck</test.runner.prefix>
      </properties>
    </profile>

    <!-- Profile for CUDA compute-sanitizer with race detection -->
    <profile>
      <id>compute-sanitizer-racecheck</id>
      <properties>
        <test.runner.prefix>compute-sanitizer --tool racecheck</test.runner.prefix>
      </properties>
    </profile>

    <!-- Profile for running with jemalloc memory profiling -->
    <profile>
      <id>jemalloc</id>
      <properties>
        <preload>${jemalloc.path}</preload>
        <jemalloc.mallocconf>prof:true,lg_prof_interval:31,lg_prof_sample:17,prof_prefix:jeprof.out</jemalloc.mallocconf>
      </properties>
    </profile>

    <!-- Profile for jemalloc leak detection -->
    <profile>
      <id>jemalloc-leak</id>
      <properties>
        <preload>${jemalloc.path}</preload>
        <jemalloc.mallocconf>prof_leak:true,lg_prof_sample:0,prof_final:true</jemalloc.mallocconf>
      </properties>
    </profile>
  </profiles>
</project>
