        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <version>${spring-boot.version}</version>
        <executions>
          <execution>
            <id>repackage</id>
            <goals>
              <goal>repackage</goal>
            </goals>
          </execution>
        </executions>
        <configuration>
          <mainClass>${start-class}</mainClass>
          <jvmArguments>${jdk9.exports}</jvmArguments>
          <environmentVariables>
            <OPENBLAS_CORETYPE>Haswell</OPENBLAS_CORETYPE>
            <OMP_NUM_THREADS>1</OMP_NUM_THREADS>
            <MKL_NUM_THREADS>1</MKL_NUM_THREADS>
            <LD_PRELOAD>${preload}</LD_PRELOAD>
            <MALLOC_CONF>${jemalloc.mallocconf}</MALLOC_CONF>
            <ASAN_OPTIONS>${test.asan.options}</ASAN_OPTIONS>
            <TEST_RUNNER_PREFIX>${test.runner.prefix}</TEST_RUNNER_PREFIX>
            <LIBJVM_PATH>${libjvm.path}</LIBJVM_PATH>
          </environmentVariables>
          <excludes>
            <exclude>
              <groupId>org.projectlombok</groupId>
              <artifactId>lombok</artifactId>
            </exclude>
          </excludes>
        </configuration>
      </plugin>
    </plugins>
