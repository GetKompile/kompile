<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
    
    <id>native</id>
    <formats>
        <format>jar</format>
    </formats>
    
    <includeBaseDirectory>false</includeBaseDirectory>
    
    <fileSets>
        <!-- Include platform-specific native libraries in JavaCPP expected location -->
        <fileSet>
            <directory>target/native/ai/kompile/tokenizers/${javacpp.platform}</directory>
            <outputDirectory>ai/kompile/tokenizers/${javacpp.platform}</outputDirectory>
            <includes>
                <!-- Only include our wrapper library, not Rust proc-macro libraries -->
                <include>**/libtokenizers_wrapper.so*</include>
                <include>**/libtokenizers_wrapper.dll*</include>
                <include>**/libtokenizers_wrapper.dylib*</include>
                <include>**/libtokenizers_wrapper.jnilib*</include>
                <include>manifest.properties</include>
            </includes>
            <excludes>
                <!-- Explicitly exclude Rust proc-macro libraries -->
                <exclude>**/libdarling_macro-*.so</exclude>
                <exclude>**/libderive_builder_macro-*.so</exclude>
                <exclude>**/libmacro_rules_attribute_proc_macro-*.so</exclude>
                <exclude>**/libmonostate_impl-*.so</exclude>
                <exclude>**/libpaste-*.so</exclude>
                <exclude>**/librustversion-*.so</exclude>
                <exclude>**/libserde_derive-*.so</exclude>
                <exclude>**/libthiserror_impl-*.so</exclude>
            </excludes>
        </fileSet>
        
        <!-- Include shared headers in JavaCPP expected location -->
        <fileSet>
            <directory>target/native/ai/kompile/tokenizers/include</directory>
            <outputDirectory>ai/kompile/tokenizers/include</outputDirectory>
            <includes>
                <include>**/*.h</include>
                <include>**/*.hpp</include>
            </includes>
        </fileSet>
        
        <!-- Include general manifest in META-INF for library discovery -->
        <fileSet>
            <directory>target/native/ai/kompile/tokenizers/${javacpp.platform}</directory>
            <outputDirectory>META-INF</outputDirectory>
            <includes>
                <include>manifest.properties</include>
            </includes>
        </fileSet>
        
        <!-- Fallback: Include essential libraries from legacy locations for backward compatibility -->
        <fileSet>
            <directory>target/native/${javacpp.platform}</directory>
            <outputDirectory>ai/kompile/tokenizers/${javacpp.platform}</outputDirectory>
            <includes>
                <!-- Only include our wrapper library -->
                <include>**/libtokenizers_wrapper.so*</include>
                <include>**/libtokenizers_wrapper.dll*</include>
                <include>**/libtokenizers_wrapper.dylib*</include>
                <include>**/libtokenizers_wrapper.jnilib*</include>
            </includes>
            <excludes>
                <!-- Explicitly exclude all Rust proc-macro libraries -->
                <exclude>**/libdarling_macro-*.so</exclude>
                <exclude>**/libderive_builder_macro-*.so</exclude>
                <exclude>**/libmacro_rules_attribute_proc_macro-*.so</exclude>
                <exclude>**/libmonostate_impl-*.so</exclude>
                <exclude>**/libpaste-*.so</exclude>
                <exclude>**/librustversion-*.so</exclude>
                <exclude>**/libserde_derive-*.so</exclude>
                <exclude>**/libthiserror_impl-*.so</exclude>
                <exclude>**/manifest.properties</exclude>
            </excludes>
        </fileSet>
    </fileSets>
    
</assembly>
