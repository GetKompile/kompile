<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>ai.kompile</groupId>
        <artifactId>tokenizers-rust</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>tokenizers-native</artifactId>
    <packaging>jar</packaging>

    <name>tokenizers-native</name>
    <description>Core tokenizers library with JavaCPP generated bindings</description>

    <dependencies>
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>tokenizers-native-preset</artifactId>
            <version>${project.version}</version>
        </dependency>


        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>tokenizers-native-preset</artifactId>
            <version>${project.version}</version>
        </dependency>


        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>tokenizers-native-preset</artifactId>
            <version>${project.version}</version>
            <classifier>${javacpp.platform}</classifier>
        </dependency>

        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>libtokenizers</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>libtokenizers</artifactId>
            <version>${project.version}</version>
            <classifier>${javacpp.platform}</classifier>
        </dependency>


        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
    </dependencies>

    <properties>
        <!-- Set explicit output directory to avoid URI parsing issues -->
        <javacpp.build.output.path>${project.build.directory}/classes/ai/kompile/bindings/${javacpp.platform}${javacpp.platform.extension}</javacpp.build.output.path>

        <javacpp.platform.library.path>natives/${javacpp.platform}</javacpp.platform.library.path>
    </properties>

    <build>
        <plugins>
            <plugin>
                <artifactId>maven-jar-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-jar</id>
                        <phase>package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <excludes>
                                <exclude>
                                    ai/kompile/bindings/${javacpp.platform}${javacpp.platform.extension}/*
                                </exclude>
                                <exclude>lib/**</exclude>
                                <exclude>*.dll</exclude>
                                <exclude>*.dylib</exclude>
                                <exclude>*.so</exclude>
                                <exclude>META-INF/native-image/${javacpp.platform}${javacpp.platform.extension}/</exclude>
                            </excludes>
                        </configuration>
                    </execution>
                    <execution>
                        <id>${javacpp.platform}${javacpp.platform.extension}</id>
                        <phase>package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <classifier>${javacpp.platform}${javacpp.platform.extension}</classifier>
                            <skipIfEmpty>true</skipIfEmpty>
                            <includes>
                                <include>
                                    ai/kompile/bindings/${javacpp.platform}${javacpp.platform.extension}/*
                                </include>
                                <include>lib/**</include>
                                <include>META-INF/native-image/${javacpp.platform}${javacpp.platform.extension}/</include>
                            </includes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>


            <plugin>
                <groupId>org.bytedeco</groupId>
                <artifactId>javacpp</artifactId>
                <version>${javacpp.version}</version>
                <dependencies>
                    <dependency>
                        <groupId>ai.kompile</groupId>
                        <artifactId>tokenizers-native-preset</artifactId>
                        <version>${project.version}</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <properties>${javacpp.platform}</properties>
                    <!-- Explicitly set output directory to avoid URI parsing issues -->
                    <outputDirectory>${javacpp.build.output.path}</outputDirectory>
                    <propertyKeysAndValues>
                        <property>
                            <name>platform.root</name>
                            <value>${javacpp.platform.root}</value>
                        </property>
                        <property>
                            <name>platform.compiler</name>
                            <value>${javacpp.platform.compiler}</value>
                        </property>
                        <property>
                            <name>platform.library.path</name>
                            <value>${javacpp.platform.library.path}</value>
                        </property>
                    </propertyKeysAndValues>
                    <classPaths>
                        <classPath>${project.build.outputDirectory}</classPath>
                    </classPaths>
                    <includePaths>
                        <includePath>${project.basedir}/../libtokenizers/target/native/include</includePath>
                        <includePath>${project.basedir}/../libtokenizers/target/native/include/tokenizers</includePath>
                        <includePath>${project.basedir}/../libtokenizers/include</includePath>
                    </includePaths>
                    <linkPaths>
                        <!-- Primary JavaCPP structure path (where buildnativetokenizers.sh outputs) -->
                        <linkPath>${project.basedir}/../libtokenizers/target/native/ai/kompile/tokenizers/${javacpp.platform}</linkPath>
                        <!-- Legacy paths for backward compatibility -->
                        <linkPath>${project.basedir}/../libtokenizers/target/native/${javacpp.platform}</linkPath>
                        <linkPath>${project.basedir}/../libtokenizers/target/native/lib64</linkPath>
                        <linkPath>${project.basedir}/../libtokenizers/target/native/lib</linkPath>
                        <!-- Build directory output location -->
                        <linkPath>${project.basedir}/../libtokenizers/build</linkPath>
                        <linkPath>${project.build.directory}/native</linkPath>
                    </linkPaths>

                    <resourcePath>${project.basedir}/../libtokenizers/target/native/${javacpp.platform}</resourcePath>
                    <buildResources>
                        <buildResource>/${javacpp.platform.library.path}/</buildResource>
                        <buildResource>/lib/</buildResource>
                        <buildResource>/</buildResource>
                        <buildResource>${project.basedir}/../libtokenizers/target/native/${javacpp.platform}</buildResource>
                    </buildResources>
                    <includeResources>
                        <includeResource>/${javacpp.platform.library.path}/include/
                        </includeResource>

                    </includeResources>
                    <linkResources>
                        <linkResource>/${javacpp.platform.library.path}/</linkResource>
                        <linkResource>/${javacpp.platform.library.path}/lib/</linkResource>
                        <!-- Primary JavaCPP structure path -->
                        <linkResource>${project.basedir}/../libtokenizers/target/native/ai/kompile/tokenizers/${javacpp.platform}</linkResource>
                        <linkResource>${project.basedir}/../libtokenizers/target/native/${javacpp.platform}</linkResource>
                    </linkResources>
                </configuration>
                <executions>
                    <execution>
                        <id>javacpp-parser</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>build</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.sourceDirectory}</outputDirectory>
                            <classOrPackageName>ai.kompile.presets.TokenizersPresets</classOrPackageName>
                        </configuration>
                    </execution>
                    <execution>
                        <id>javacpp-compiler</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>build</goal>
                        </goals>
                        <configuration>
                            <classOrPackageName>ai.kompile.bindings.TokenizersNative</classOrPackageName>
                            <copyLibs>true</copyLibs>
                            <copyResources>true</copyResources>
                            <configDirectory>${project.build.directory}/classes/META-INF/native-image/${javacpp.platform}${javacpp.platform.extension}/</configDirectory>
                            <outputDirectory>${javacpp.build.output.path}</outputDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Copy libtokenizers_wrapper.so to the same location as libjnitokenizers.so -->
            <!-- This is required because libjnitokenizers.so dynamically links to libtokenizers_wrapper.so -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>copy-wrapper-lib</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <!-- Copy wrapper library to the same directory as the JNI library -->
                                <echo message="Copying libtokenizers_wrapper to ${javacpp.build.output.path}"/>
                                <copy todir="${javacpp.build.output.path}" failonerror="false" overwrite="true">
                                    <fileset dir="${project.basedir}/../libtokenizers/target/native/ai/kompile/tokenizers/${javacpp.platform}">
                                        <include name="libtokenizers_wrapper.so*"/>
                                        <include name="libtokenizers_wrapper.dylib*"/>
                                        <include name="libtokenizers_wrapper.dll*"/>
                                        <include name="libtokenizers_ffi.so*"/>
                                        <include name="libtokenizers_ffi.dylib*"/>
                                        <include name="libtokenizers_ffi.dll*"/>
                                    </fileset>
                                </copy>
                                <!-- Debug: List what was copied -->
                                <echo message="Native libraries in output directory:"/>
                                <exec executable="ls" failonerror="false">
                                    <arg value="-la"/>
                                    <arg value="${javacpp.build.output.path}"/>
                                </exec>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>linux-x86_64</id>
            <activation>
                <os>
                    <family>unix</family>
                    <name>linux</name>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>linux-x86_64</javacpp.platform>
                <javacpp.platform.root>/usr</javacpp.platform.root>
                <javacpp.platform.compiler>g++</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>windows-x86_64</id>
            <activation>
                <os>
                    <family>windows</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>windows-x86_64</javacpp.platform>
                <javacpp.platform.compiler>cl.exe</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>macosx-x86_64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>x86_64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>macosx-x86_64</javacpp.platform>
                <javacpp.platform.compiler>clang++</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>macosx-arm64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>aarch64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>macosx-arm64</javacpp.platform>
                <javacpp.platform.compiler>clang++</javacpp.platform.compiler>
            </properties>
        </profile>
    </profiles>

</project>