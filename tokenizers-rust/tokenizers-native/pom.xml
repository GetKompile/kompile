<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.tokenizers</groupId>
        <artifactId>tokenizers-rust</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>tokenizers-native</artifactId>
    <packaging>jar</packaging>

    <name>tokenizers-native</name>
    <description>Core tokenizers library with JavaCPP generated bindings</description>

    <dependencies>
        <dependency>
            <groupId>org.tokenizers</groupId>
            <artifactId>tokenizers-native-preset</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.tokenizers</groupId>
            <artifactId>libtokenizers</artifactId>
            <version>${project.version}</version>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
    </dependencies>

    <properties>
        <!-- Set explicit output directory to avoid URI parsing issues -->
        <javacpp.platform.library.path>natives/${javacpp.platform}</javacpp.platform.library.path>
        <javacpp.outputDirectory>${project.build.directory}/natives/${javacpp.platform}</javacpp.outputDirectory>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>copy-native-libs</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>unpack-dependencies</goal>
                        </goals>
                        <configuration>
                            <includeGroupIds>org.tokenizers</includeGroupIds>
                            <includeArtifactIds>libtokenizers</includeArtifactIds>
                            <includeClassifiers>native</includeClassifiers>
                            <outputDirectory>${project.build.directory}/native</outputDirectory>
                            <includes>**/*.so,**/*.dll,**/*.dylib,**/*.jnilib</includes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.bytedeco</groupId>
                <artifactId>javacpp</artifactId>
                <version>${javacpp.version}</version>
                <dependencies>
                    <dependency>
                        <groupId>org.tokenizers</groupId>
                        <artifactId>tokenizers-native-preset</artifactId>
                        <version>${project.version}</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <properties>${javacpp.platform}</properties>
                    <!-- Explicitly set output directory to avoid URI parsing issues -->
                    <outputDirectory>${javacpp.outputDirectory}</outputDirectory>
                    <propertyKeysAndValues>
                        <property>
                            <name>platform.root</name>
                            <value>${javacpp.platform.root}</value>
                        </property>
                        <property>
                            <name>platform.compiler</name>
                            <value>${javacpp.platform.compiler}</value>
                        </property>
                        <property>
                            <name>platform.library.path</name>
                            <value>${javacpp.platform.library.path}</value>
                        </property>
                    </propertyKeysAndValues>
                    <classPaths>
                        <classPath>${project.build.outputDirectory}</classPath>
                    </classPaths>
                    <includePaths>
                        <includePath>${project.basedir}/../libtokenizers/target/native/include</includePath>
                        <includePath>${project.basedir}/../libtokenizers/target/native/include/tokenizers</includePath>
                        <includePath>${project.basedir}/../libtokenizers/include</includePath>
                    </includePaths>
                    <linkPaths>
                        <linkPath>${project.basedir}/../libtokenizers/target/native/lib64</linkPath>
                        <linkPath>${project.basedir}/../libtokenizers/target/native/linux-x86_64</linkPath>
                        <linkPath>${project.build.directory}/native</linkPath>
                    </linkPaths>
                </configuration>
                <executions>
                    <execution>
                        <id>javacpp-parser</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>build</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.sourceDirectory}</outputDirectory>
                            <classOrPackageName>org.tokenizers.presets.TokenizersPresets</classOrPackageName>
                        </configuration>
                    </execution>
                    <execution>
                        <id>javacpp-compiler</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>build</goal>
                        </goals>
                        <configuration>
                            <classOrPackageName>org.tokenizers.bindings.TokenizersNative</classOrPackageName>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>linux-x86_64</id>
            <activation>
                <os>
                    <family>unix</family>
                    <name>linux</name>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>linux-x86_64</javacpp.platform>
                <javacpp.platform.root>/usr</javacpp.platform.root>
                <javacpp.platform.compiler>g++</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>windows-x86_64</id>
            <activation>
                <os>
                    <family>windows</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>windows-x86_64</javacpp.platform>
                <javacpp.platform.compiler>cl.exe</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>macosx-x86_64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>x86_64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>macosx-x86_64</javacpp.platform>
                <javacpp.platform.compiler>clang++</javacpp.platform.compiler>
            </properties>
        </profile>

        <profile>
            <id>macosx-arm64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>aarch64</arch>
                </os>
            </activation>
            <properties>
                <javacpp.platform>macosx-arm64</javacpp.platform>
                <javacpp.platform.compiler>clang++</javacpp.platform.compiler>
            </properties>
        </profile>
    </profiles>

</project>