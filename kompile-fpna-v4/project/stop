#!/usr/bin/env bash
# Stop the FP&A v3 application and its separate model staging server.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR"
RUN_DIR="$PROJECT_DIR/data/run"

APP_PORT="${APP_PORT:-8080}"
STAGING_PORT="${STAGING_PORT:-8090}"
APP_URL="${APP_URL:-http://localhost:${APP_PORT}}"

unique_pids() {
    awk 'NF && !seen[$1]++ { print $1 }'
}

pid_from_file() {
    local file="$1"
    if [ -f "$file" ]; then
        local pid
        pid="$(tr -d '[:space:]' < "$file" || true)"
        if [ -n "$pid" ] && kill -0 "$pid" >/dev/null 2>&1; then
            echo "$pid"
        fi
    fi
    return 0
}

pids_for_pattern() {
    local pattern="$1"
    pgrep -f "$pattern" 2>/dev/null || true
}

http_ok() {
    local url="$1"
    curl -fsS --max-time 5 "$url" >/dev/null 2>&1
}

cancel_active_unified_crawls() {
    local active_url="$APP_URL/api/unified-crawl/jobs/active"

    if ! command -v curl >/dev/null 2>&1; then
        echo "curl not available; skipping crawl cancellation."
        return 0
    fi
    if ! command -v jq >/dev/null 2>&1; then
        echo "jq not available; skipping crawl cancellation."
        return 0
    fi
    if ! http_ok "$APP_URL/api/unified-crawl/source-types"; then
        echo "FP&A v3 app API is not reachable; skipping crawl cancellation."
        return 0
    fi

    local active_jobs
    active_jobs="$(curl -fsS --max-time 20 "$active_url" 2>/dev/null || true)"
    if [ -z "$active_jobs" ] || [ "$(jq 'length' <<< "$active_jobs" 2>/dev/null || echo 0)" -eq 0 ]; then
        echo "No active unified crawls to cancel."
        curl -fsS --max-time 20 -X POST "$APP_URL/api/unified-crawl/jobs/cleanup" >/dev/null 2>&1 || true
        return 0
    fi

    echo "Cancelling active unified crawls before shutdown."
    jq -r '.[] | .jobId // empty' <<< "$active_jobs" | while read -r job_id; do
        if [ -n "$job_id" ]; then
            echo "Cancelling unified crawl: $job_id"
            curl -fsS --max-time 20 -X POST "$APP_URL/api/unified-crawl/jobs/$job_id/cancel" >/dev/null 2>&1 || true
        fi
    done
    curl -fsS --max-time 20 -X POST "$APP_URL/api/unified-crawl/jobs/cleanup" >/dev/null 2>&1 || true
}

stop_embedding_subprocesses() {
    local pids
    pids="$(pids_for_pattern 'ai.kompile.embedding.anserini.subprocess.EmbeddingSubprocessMain' | unique_pids)"

    if [ -z "$pids" ]; then
        echo "Embedding subprocess is not running."
        return 0
    fi

    echo "Stopping embedding subprocess: $(echo "$pids" | tr '\n' ' ')"
    kill $pids >/dev/null 2>&1 || true

    local waited=0
    while [ "$waited" -lt 15 ]; do
        local still_running=""
        local pid
        for pid in $pids; do
            if kill -0 "$pid" >/dev/null 2>&1; then
                still_running="${still_running}${pid} "
            fi
        done

        if [ -z "$still_running" ]; then
            echo "Embedding subprocess stopped."
            return 0
        fi

        sleep 1
        waited=$((waited + 1))
    done

    echo "Forcing embedding subprocess shutdown: $still_running"
    kill -KILL $still_running >/dev/null 2>&1 || true
}

stop_llm_serving_subprocesses() {
    local pids
    pids="$(pids_for_pattern 'ai.kompile.app.subprocess.ServingSubprocessMain' | unique_pids)"

    if [ -z "$pids" ]; then
        echo "LLM serving subprocess is not running."
        return 0
    fi

    echo "Stopping LLM serving subprocess: $(echo "$pids" | tr '\n' ' ')"
    kill $pids >/dev/null 2>&1 || true

    local waited=0
    while [ "$waited" -lt 15 ]; do
        local still_running=""
        local pid
        for pid in $pids; do
            if kill -0 "$pid" >/dev/null 2>&1; then
                still_running="${still_running}${pid} "
            fi
        done

        if [ -z "$still_running" ]; then
            echo "LLM serving subprocess stopped."
            return 0
        fi

        sleep 1
        waited=$((waited + 1))
    done

    echo "Forcing LLM serving subprocess shutdown: $still_running"
    kill -KILL $still_running >/dev/null 2>&1 || true
}

stop_stderr_filters() {
    local pids=""
    local file
    for file in "$RUN_DIR"/*.stderr-filter.pid; do
        [ -e "$file" ] || continue
        local pid
        pid="$(pid_from_file "$file")"
        if [ -n "${pid:-}" ]; then
            pids="${pids}${pid}
"
        fi
        rm -f "$file"
    done

    pids="$(printf '%s' "$pids" | unique_pids)"
    if [ -n "$pids" ]; then
        echo "Stopping stderr filter process(es): $(echo "$pids" | tr '\n' ' ')"
        kill $pids >/dev/null 2>&1 || true
    fi
    rm -f "$RUN_DIR"/*.stderr.fifo "$RUN_DIR/stderr-filter.awk" 2>/dev/null || true
}

stop_service() {
    local name="$1"
    local pid_file="$2"
    local pattern="$3"
    local pids

    pids="$(
        {
            pid_from_file "$pid_file"
            pids_for_pattern "$pattern"
        } | unique_pids
    )"

    if [ -z "$pids" ]; then
        echo "$name is not running."
        rm -f "$pid_file"
        return 0
    fi

    echo "Stopping $name: $(echo "$pids" | tr '\n' ' ')"
    kill $pids >/dev/null 2>&1 || true

    local waited=0
    while [ "$waited" -lt 30 ]; do
        local still_running=""
        local pid
        for pid in $pids; do
            if kill -0 "$pid" >/dev/null 2>&1; then
                still_running="${still_running}${pid} "
            fi
        done

        if [ -z "$still_running" ]; then
            rm -f "$pid_file"
            echo "$name stopped."
            return 0
        fi

        sleep 1
        waited=$((waited + 1))
    done

    echo "Forcing $name shutdown: $still_running"
    kill -KILL $still_running >/dev/null 2>&1 || true
    rm -f "$pid_file"
}

cleanup_stale_embedding_tmp() {
    if pgrep -f 'ai.kompile.embedding.anserini.subprocess.EmbeddingSubprocessMain' >/dev/null 2>&1; then
        echo "Embedding subprocess still running; leaving JavaCPP temp directories in place."
        return 0
    fi
    find /tmp -maxdepth 1 -type d -name 'embedding-subprocess-javacpp-*' -print -exec rm -rf {} + 2>/dev/null || true
}

mkdir -p "$RUN_DIR"

cancel_active_unified_crawls

stop_service \
    "FP&A v3 app" \
    "$RUN_DIR/app.pid" \
    "java .* -jar .*kompile-fpna-v3-0.1.0-SNAPSHOT.jar"

stop_llm_serving_subprocesses

stop_embedding_subprocesses

stop_service \
    "model staging server" \
    "$RUN_DIR/staging.pid" \
    "kompile-model-staging-0.1.0-SNAPSHOT-exec.jar.*--server.port=${STAGING_PORT}"

stop_stderr_filters
cleanup_stale_embedding_tmp

# Remove H2 database lock file to prevent startup failures on restart
rm -f "$PROJECT_DIR/data/kompile-db.mv.db.lock.db" 2>/dev/null || true

echo "FP&A v3 runtime stopped."
