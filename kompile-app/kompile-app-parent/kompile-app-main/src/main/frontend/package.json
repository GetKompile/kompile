{
  "name": "rag-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report playwright-report",
    "e2e:cli": "playwright test --config=playwright-cli.config.ts",
    "e2e:cli:help": "playwright test --config=playwright-cli.config.ts cli-help",
    "e2e:cli:build": "playwright test --config=playwright-cli.config.ts cli-build",
    "e2e:cli:chat": "playwright test --config=playwright-cli.config.ts cli-chat",
    "e2e:cli:wizard": "playwright test --config=playwright-cli.config.ts cli-wizard",
    "e2e:cli:report": "playwright show-report playwright-report-cli"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "19.2.11",
    "@angular/cdk": "19.2.11",
    "@angular/common": "19.2.11",
    "@angular/compiler": "19.2.11",
    "@angular/core": "19.2.11",
    "@angular/forms": "19.2.11",
    "@angular/material": "19.2.11",
    "@angular/platform-browser": "19.2.11",
    "@angular/platform-browser-dynamic": "19.2.11",
    "@angular/router": "19.2.11",
    "@stomp/stompjs": "^7.0.0",
    "d3": "^7.8.5",
    "highlight.js": "^11.11.0",
    "marked": "^15.0.0",
    "mermaid": "^11.15.0",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.11",
    "@angular/cli": "^19.2.11",
    "@angular/compiler-cli": "19.2.11",
    "@playwright/test": "^1.60.0",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.9.1",
    "@types/sockjs-client": "^1.5.4",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
