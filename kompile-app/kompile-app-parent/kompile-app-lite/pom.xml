<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>ai.kompile</groupId>
        <artifactId>kompile-app-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>kompile-app-lite</artifactId>
    <name>Kompile App - Lite (Self-Contained Chat + RAG + Graph RAG)</name>
    <description>Lightweight self-contained application with chat, RAG, graph RAG, and model management</description>

    <properties>
        <start-class>ai.kompile.lite.LiteApplication</start-class>
    </properties>

    <dependencies>
        <!-- Spring Boot -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- Kompile Core -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-app-core</artifactId>
        </dependency>

        <!-- Anserini (search + indexing) -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-app-anserini</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.apache.logging.log4j</groupId>
                    <artifactId>log4j-core</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- Embedding -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-embedding-anserini</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.mockito</groupId>
                    <artifactId>mockito-all</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- Vector Store -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-vectorstore-anserini</artifactId>
        </dependency>

        <!-- Knowledge Graph (matrix-based) -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-knowledge-graph</artifactId>
        </dependency>

        <!-- Model Manager -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-model-manager</artifactId>
        </dependency>

        <!-- Model Staging -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-model-staging</artifactId>
        </dependency>

        <!-- Chat History -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-chat-history</artifactId>
        </dependency>

        <!-- Chunker -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-chunker-sentence</artifactId>
        </dependency>

        <!-- Document Loaders -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-loader-pdf-extended</artifactId>
        </dependency>

        <!-- RAG Tool -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-tool-rag</artifactId>
        </dependency>

        <!-- LLM Providers (optional, conditional) -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-app-openai-llm</artifactId>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-app-anthropic-llm</artifactId>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-app-gemini-llm</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- ND4J -->
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>nd4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.bytedeco</groupId>
            <artifactId>javacpp</artifactId>
            <version>${javacpp.version}</version>
        </dependency>

        <!-- Logging -->
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-to-slf4j</artifactId>
        </dependency>

        <!-- Jackson -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <fork>true</fork>
                    <release>${java.version}</release>
                    <parameters>true</parameters>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <mainClass>${start-class}</mainClass>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>repackage</id>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                        <configuration>
                            <!-- Use classifier so original JAR is preserved for native-image -->
                            <classifier>exec</classifier>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Native image profile -->
        <profile>
            <id>native</id>
            <activation>
                <property>
                    <name>kompile.dist</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <!-- Spring Boot AOT processing — required for native image -->
                    <plugin>
                        <groupId>org.springframework.boot</groupId>
                        <artifactId>spring-boot-maven-plugin</artifactId>
                        <version>${spring-boot.version}</version>
                        <executions>
                            <execution>
                                <id>process-aot</id>
                                <goals>
                                    <goal>process-aot</goal>
                                </goals>
                            </execution>
                        </executions>
                        <configuration>
                            <mainClass>${start-class}</mainClass>
                        </configuration>
                    </plugin>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <extensions>true</extensions>
                        <executions>
                            <execution>
                                <id>build-native</id>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                                <phase>package</phase>
                            </execution>
                        </executions>
                        <configuration>
                            <mainClass>${start-class}</mainClass>
                            <imageName>${project.artifactId}-native</imageName>
                            <buildArgs>
                                <buildArg>-J-Xmx16g</buildArg>
                                <buildArg>--verbose</buildArg>
                                <buildArg>--no-fallback</buildArg>
                                <buildArg>--allow-incomplete-classpath</buildArg>
                                <buildArg>-H:+ReportExceptionStackTraces</buildArg>
                                <buildArg>-H:DeadlockWatchdogInterval=30</buildArg>
                                <buildArg>-H:+DeadlockWatchdogExitOnTimeout</buildArg>
                                <buildArg>--enable-url-protocols=https,http</buildArg>
                                <buildArg>-Dorg.bytedeco.javacpp.nopointergc=true</buildArg>
                                <!-- Build-time initialization (logging + ND4J deallocation) -->
                                <buildArg>--initialize-at-build-time=org.slf4j</buildArg>
                                <buildArg>--initialize-at-build-time=ch.qos.logback</buildArg>
                                <buildArg>--initialize-at-build-time=org.nd4j.linalg.api.memory.deallocation</buildArg>
                                <!-- Runtime initialization (ND4J, JavaCPP, Lucene, JNI) -->
                                <buildArg>--initialize-at-run-time=org.bytedeco.javacpp</buildArg>
                                <buildArg>--initialize-at-run-time=org.eclipse.deeplearning4j</buildArg>
                                <buildArg>--initialize-at-run-time=org.nd4j</buildArg>
                                <buildArg>--initialize-at-run-time=org.apache.lucene</buildArg>
                                <buildArg>--initialize-at-run-time=io.netty.channel.epoll.Epoll</buildArg>
                                <buildArg>--initialize-at-run-time=com.sun.jna.Native</buildArg>
                                <buildArg>--initialize-at-run-time=net.bytebuddy</buildArg>
                                <buildArg>-H:+AllowDeprecatedBuilderClassesOnImageClasspath</buildArg>
                                <!-- Exclude ByteBuddy bytecode provider from ServiceLoader -->
                                <buildArg>-H:ServiceLoaderFeatureExcludeServices=org.hibernate.bytecode.spi.BytecodeProvider</buildArg>
                                <!-- Lite-specific native-image configs -->
                                <buildArg>-H:ConfigurationFileDirectories=${project.basedir}/src/main/resources/META-INF/native-image/lite</buildArg>
                                <!-- Resource inclusion -->
                                <buildArg>-H:IncludeResources=application.*</buildArg>
                                <buildArg>-H:IncludeResources=META-INF/native-image/.*\.json</buildArg>
                                <buildArg>-H:IncludeResources=org/bytedeco/.*</buildArg>
                                <buildArg>-H:IncludeResources=log4j2\.component\.properties</buildArg>
                                <buildArg>-H:IncludeResources=model-sources\.yml</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Model bundling profile -->
        <profile>
            <id>bundle-models</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>download-models</id>
                                <phase>prepare-package</phase>
                                <goals>
                                    <goal>java</goal>
                                </goals>
                                <configuration>
                                    <mainClass>ai.kompile.modelmanager.KompileModelManager</mainClass>
                                    <arguments>
                                        <argument>--download</argument>
                                        <argument>bge-base-en-v1.5</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
