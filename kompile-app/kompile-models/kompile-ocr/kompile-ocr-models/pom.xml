<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>ai.kompile</groupId>
        <artifactId>kompile-ocr</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>kompile-ocr-models</artifactId>
    <name>Kompile OCR - SameDiff Model Implementations</name>
    <description>SameDiff-based OCR model implementations for text detection, recognition, table extraction, and layout analysis</description>

    <dependencies>
        <!-- OCR Core interfaces -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-ocr-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- OCR Data Pipeline for parsing -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-ocr-datapipeline</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Model Manager for downloading and caching models -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-model-manager</artifactId>
        </dependency>

        <!-- ND4J and SameDiff -->
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>nd4j-api</artifactId>
            <version>${nd4j.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>samediff-import-api</artifactId>
            <version>${nd4j.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>samediff-import-onnx</artifactId>
            <version>${nd4j.version}</version>
        </dependency>

        <!-- KV Cache integration (optional - for persistent managed KV cache) -->
        <dependency>
            <groupId>ai.kompile</groupId>
            <artifactId>kompile-kvcache</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>

        <!-- SameDiff LLM and VLM modules (versions managed by parent) -->
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>samediff-llm</artifactId>
        </dependency>
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>samediff-vlm</artifactId>
        </dependency>

        <!-- Tokenizers (from DL4J nd4j-tokenizers, transitively via samediff-llm/vlm) -->
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>tokenizers-native</artifactId>
            <version>${nd4j.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.deeplearning4j</groupId>
            <artifactId>tokenizers-native</artifactId>
            <version>${nd4j.version}</version>
            <classifier>${javacpp.platform}</classifier>
        </dependency>

        <!-- Image processing -->
        <dependency>
            <groupId>org.apache.pdfbox</groupId>
            <artifactId>pdfbox</artifactId>
            <version>3.0.4</version>
        </dependency>

        <!-- Spring -->
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-context</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
        </dependency>

        <!-- SLF4J -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
